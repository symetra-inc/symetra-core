generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Essencial para o Supabase
}

// ==========================================
// 1. SISTEMA DE ACESSO E HIERARQUIA (RBAC)
// ==========================================

enum Role {
  SUPER_ADMIN
  AGENCY
  CLINIC
}

model User {
  id           String   @id @default(uuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         Role     @default(CLINIC)

  // Controle de Acesso: A qual entidade este usuário pertence?
  agency_id    String?
  agency       Agency?  @relation(fields: [agency_id], references: [id])

  clinic_id    String?
  clinic       Clinic?  @relation(fields: [clinic_id], references: [id])

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

model Agency {
  id         String   @id @default(uuid())
  name       String
  tier       String   @default("CERTIFIED") // CERTIFIED, SILVER, GOLD
  
  users      User[]     // Operadores desta agência
  clinics    Clinic[]   // Carteira de clientes desta agência

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// ==========================================
// 2. O MOTOR DA CLÍNICA E DA IA (SERENA)
// ==========================================

model Clinic {
  id                 String   @id @default(uuid())
  name               String
  whatsapp_number_id String   @unique
  
  // Symetra Protocol: A qual agência esta clínica pertence?
  agency_id          String?
  agency             Agency?  @relation(fields: [agency_id], references: [id])
  users              User[]   // Donos/Médicos que acessam o painel
  
  // Integração Asaas
  asaas_api_key      String?
  asaas_wallet_id    String?
  
  // Regras Dinâmicas da IA
  reservation_fee    Int      @default(100)
  working_hours      String   @default("Segunda a Sexta das 08h às 18h. Sábados até 12h. Domingos fechado.")
  allowed_procedures String   @default("Botox (Toxina Botulínica), Preenchimentos (Labial, Malar, Mandíbula), Bioestimuladores de Colágeno e Fios de PDO")

  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  leads              Lead[]
  appointments       Appointment[]
}

model Lead {
  id           String   @id @default(uuid())
  phone        String   @unique
  name         String?
  is_curious   Boolean  @default(false)

  clinic_id    String
  clinic       Clinic   @relation(fields: [clinic_id], references: [id])

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  appointments Appointment[]
}

model Appointment {
  id               String   @id @default(uuid())
  procedure        String
  status           AppointmentStatus @default(PENDING) // Correção aplicada aqui!
  target_date      DateTime
  locked_at        DateTime @default(now()) // A Trava Atômica

  asaas_payment_id String?  @unique
  asaas_qr_code    String?

  clinic_id        String
  clinic           Clinic   @relation(fields: [clinic_id], references: [id])

  lead_id          String
  lead             Lead     @relation(fields: [lead_id], references: [id])

  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@unique([clinic_id, target_date]) 
}

enum AppointmentStatus {
  PENDING   // Pix gerado, aguardando pagamento
  PAID      // Handoff autorizado para a secretária
  EXPIRED   // Pix não pago a tempo, locked_at liberado
  CANCELED
}